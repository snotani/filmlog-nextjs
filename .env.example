# Copy this file to .env.local and fill in real values.
# Never commit .env.local (it's gitignored).

# Local SQLite database file (relative to the prisma/ folder)
DATABASE_URL="file:./dev.db"

# TMDB API key for fetching film data
# Get one for free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=""

# Auth.js (set up in Phase 3)
# Generate with: npx auth secret
AUTH_SECRET=""

# Required by Auth.js to know where the app is hosted in dev
AUTH_URL="http://localhost:3000"

# Google OAuth (Phase 3 stretch)
# https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend transactional email (Phase 8)
# https://resend.com/api-keys
RESEND_API_KEY=""
